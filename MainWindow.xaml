<Window x:Class="ClinicManagementApplication.MainWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

        xmlns:local="clr-namespace:WpfApp3"

        mc:Ignorable="d"

        Title="نظام إدارة العيادة الطبية"

        Height="820" Width="1300"

        WindowStyle="None" 

        AllowsTransparency="True" 

        Background="Transparent"

        MouseLeftButtonDown="Window_MouseLeftButtonDown"

        WindowStartupLocation="CenterScreen"

        FlowDirection="RightToLeft"

        FontFamily="Segoe UI"

        WindowState="Maximized" 

        MinHeight="600" MinWidth="1000"

        d:DesignHeight="800" d:DesignWidth="1300"

        >



    <!-- ══════════════════════════════════════════════════════════

         موارد عامة: ألوان، أنماط، قوالب تحكم

    ══════════════════════════════════════════════════════════════ -->

    <Window.Resources>





    </Window.Resources>



    <!-- ══════════════════════════════════════════════════════════

         إطار النافذة الخارجي (زوايا مدورة + ظل عميق)

    ══════════════════════════════════════════════════════════════ -->

    <Border CornerRadius="18" ClipToBounds="True" Effect="{StaticResource WindowShadow}">



        <!-- ══════════════════════════════════════════════════════════

             الشبكة الرئيسية:

             ┌──────────────────────┬──────────────────────────────┐

             │  عمود 0 (235px)      │  عمود 1 (*)                  │

             │   الشريط الجانبي    │   الرأس + المحتوى            │

             └──────────────────────┴──────────────────────────────┘

        ══════════════════════════════════════════════════════════════ -->

        <Grid Background="#F0F3F8">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="235"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>



            <!-- ══════════════════════════════════════════════════

                 عمود 0 — الشريط الجانبي

            ══════════════════════════════════════════════════════ -->

            <Border Grid.Column="0" Panel.ZIndex="10">

                <Border.Background>

                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">

                        <GradientStop Color="#1A2635" Offset="0"/>

                        <GradientStop Color="#243447" Offset="1"/>

                    </LinearGradientBrush>

                </Border.Background>

                <Border.Effect>

                    <DropShadowEffect Color="#000000" Direction="0" ShadowDepth="5" BlurRadius="20" Opacity="0.15"/>

                </Border.Effect>



                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <!-- شعار -->

                        <RowDefinition Height="*"/>

                        <!-- قائمة -->

                        <RowDefinition Height="Auto"/>

                        <!-- ملف المستخدم -->

                    </Grid.RowDefinitions>



                    <!-- ── الشعار ── -->

                    <Border Grid.Row="0" Padding="15,20" BorderThickness="0,0,0,1" BorderBrush="#263647">

                        <Grid>

                            <Grid.RowDefinitions>

                                <RowDefinition Height="Auto"/>

                                <RowDefinition Height="Auto"/>

                            </Grid.RowDefinitions>



                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">

                                <Button Click="Button_Click" Cursor="Hand" ToolTip="إغلاق">

                                    <Button.Template>

                                        <ControlTemplate TargetType="Button">

                                            <Border x:Name="bg" Width="14" Height="14" CornerRadius="7" Background="#FF5F56" Margin="4,0">

                                                <TextBlock Text="×" Foreground="#4A0000" FontSize="10" FontWeight="Bold" 

                                       HorizontalAlignment="Center" VerticalAlignment="Center" 

                                       Visibility="Collapsed" x:Name="icon"/>

                                            </Border>

                                            <ControlTemplate.Triggers>

                                                <Trigger Property="IsMouseOver" Value="True">

                                                    <Setter TargetName="icon" Property="Visibility" Value="Visible"/>

                                                </Trigger>

                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>

                                    </Button.Template>

                                </Button>



                                <Button Click="Button_Click_1" Cursor="Hand" ToolTip="تصغير">

                                    <Button.Template>

                                        <ControlTemplate TargetType="Button">

                                            <Border x:Name="bg" Width="14" Height="14" CornerRadius="7" Background="#FFBD2E" Margin="4,0">

                                                <TextBlock Text="-" Foreground="#5A3E00" FontSize="12" FontWeight="Bold" 

                                       HorizontalAlignment="Center" VerticalAlignment="Center" 

                                       Visibility="Collapsed" x:Name="icon" Margin="0,-2,0,0"/>

                                            </Border>

                                            <ControlTemplate.Triggers>

                                                <Trigger Property="IsMouseOver" Value="True">

                                                    <Setter TargetName="icon" Property="Visibility" Value="Visible"/>

                                                </Trigger>

                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>

                                    </Button.Template>

                                </Button>

                            </StackPanel>



                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">

                                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">

                                    <TextBlock Text="عيادتي الذكية"

                           FontFamily="Segoe UI" FontSize="15"

                           FontWeight="Bold" Foreground="#FFFFFF"/>

                                    <TextBlock Text="نظام إدارة العيادات"

                           FontFamily="Segoe UI" FontSize="9"

                           Foreground="#5D7A95" Margin="0,2,0,0" HorizontalAlignment="Right"/>

                                </StackPanel>



                                <Border Width="40" Height="40" CornerRadius="12">

                                    <Border.Background>

                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">

                                            <GradientStop Color="#3498DB" Offset="0"/>

                                            <GradientStop Color="#2980B9" Offset="1"/>

                                        </LinearGradientBrush>

                                    </Border.Background>

                                    <Border.Effect>

                                        <DropShadowEffect Color="#3498DB" ShadowDepth="0" BlurRadius="10" Opacity="0.4"/>

                                    </Border.Effect>

                                    <TextBlock Text="🌙" FontSize="18" Foreground="White"

                           HorizontalAlignment="Center"

                           VerticalAlignment="Center"/>

                                </Border>

                            </StackPanel>

                        </Grid>

                    </Border>

                    <!-- ── قائمة التنقل ── -->

                    <ScrollViewer Grid.Row="1"

                                  VerticalScrollBarVisibility="Auto"

                                  HorizontalScrollBarVisibility="Disabled">

                        <StackPanel Margin="0,12,0,0">



                            <!-- عنوان: القائمة الرئيسية -->

                            <TextBlock Text="القائمة الرئيسية"

                                       FontFamily="Segoe UI" FontSize="9.5"

                                       FontWeight="SemiBold" Foreground="#3D5A72"

                                       HorizontalAlignment="Right"

                                       Margin="0,6,24,8"/>



                            <!-- الرئيسية (نشطة) -->

                            <Button x:Name="BtnHome" Tag="home"

                                    Style="{StaticResource NavBtnActive}" Click="BtnHome_Click"

                                    >

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="الرئيسية" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="🏠" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- المرضى -->

                            <Button x:Name="BtnPatients" Tag="patients"

                                    Style="{StaticResource NavBtn}" Click="BtnPatients_Click" >

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="المرضى" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="👥" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- المواعيد -->

                            <Button x:Name="BtnAppointments" Tag="appointments"

                                    Style="{StaticResource NavBtn}" Click="BtnAppointments_Click" >

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="المواعيد" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="📅" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- الأطباء -->

                            <Button x:Name="BtnDoctors" Tag="doctors"

                                    Style="{StaticResource NavBtn}" Click="BtnDoctors_Click" >

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="الأطباء" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="🩺" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- الصيدلية -->

                            <Button x:Name="BtnPharmacy" Tag="pharmacy"

                                    Style="{StaticResource NavBtn}" Click="BtnPharmacy_Click" >

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="الصيدلية" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="💊" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- الفواتير -->

                            <Button x:Name="BtnBilling" Tag="billing"

                                    Style="{StaticResource NavBtn}" Click="BtnBilling_Click" >

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="الفواتير والمدفوعات" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="💳" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- التقارير -->

                            <Button x:Name="BtnReports" Tag="reports"

                                    Style="{StaticResource NavBtn}" Click="BtnReports_Click">

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="التقارير والإحصاء" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="📊" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- فاصل -->

                            <Border Height="1" Background="#263647" Margin="20,14"/>



                            <!-- عنوان: الإدارة -->

                            <TextBlock Text="الإدارة والنظام"

                                       FontFamily="Segoe UI" FontSize="9.5"

                                       FontWeight="SemiBold" Foreground="#3D5A72"

                                       HorizontalAlignment="Right"

                                       Margin="0,0,24,8"/>



                            <!-- إدارة المخزون -->

                            <Button Style="{StaticResource NavBtn}">

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="إدارة المخزون" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="📦" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- الموظفون -->

                            <Button Style="{StaticResource NavBtn}">

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="الموظفون" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="🪪" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- الإعدادات -->

                            <Button Style="{StaticResource NavBtn}" Click="Button_Click_2">

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="الإعدادات" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="⚙️" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                            <!-- الدعم الفني -->

                            <Button Style="{StaticResource NavBtn}" Click="Button_Click_3">

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                    <TextBlock Text="الدعم الفني" FontFamily="Segoe UI" VerticalAlignment="Center"/>

                                    <TextBlock Text="❓" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                </StackPanel>

                            </Button>



                        </StackPanel>

                    </ScrollViewer>



                    <!-- ── بطاقة ملف المستخدم ── -->

                    <Border Grid.Row="2" Margin="15,10" Padding="8"

        CornerRadius="16" Background="#2C3E50"

        BorderThickness="1" BorderBrush="#34495E">

                        <Grid>

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="Auto"/>

                                <ColumnDefinition Width="*"/>

                                <ColumnDefinition Width="Auto"/>

                            </Grid.ColumnDefinitions>



                            <Grid Grid.Column="2">

                                <Border Width="42" Height="42" CornerRadius="12">

                                    <Border.Background>

                                        <ImageBrush ImageSource="https://ui-avatars.com/api/?name=Admin&amp;background=3498db&amp;color=fff"/>

                                    </Border.Background>

                                </Border>

                                <Border Width="12" Height="12" Background="#2ECC71" 

                    CornerRadius="6" BorderBrush="#2C3E50" BorderThickness="2"

                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-2,-2"/>

                            </Grid>



                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">

                                <TextBlock Text="د. محمد علي" FontWeight="Bold" FontSize="12" Foreground="White" HorizontalAlignment="Right"/>

                                <TextBlock Text="مدير النظام" FontSize="10" Foreground="#BDC3C7" HorizontalAlignment="Right"/>

                            </StackPanel>



                            <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="الإعدادات والخروج">

                                <TextBlock Text="⋮" Foreground="#95A5A6" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

                            </Button>

                        </Grid>

                    </Border>

                </Grid>

            </Border>

            <!-- نهاية الشريط الجانبي -->



            <!-- ══════════════════════════════════════════════════

                 عمود 1 — منطقة المحتوى الرئيسي

                 ┌──────────────────────────────────────────────┐

                 │  صف 0: شريط الرأس (68px)                    │

                 │  صف 1: المحتوى القابل للتمرير (*)           │

                 └──────────────────────────────────────────────┘

            ══════════════════════════════════════════════════════ -->

            <Grid Grid.Column="1">

                <Grid.RowDefinitions>

                    <RowDefinition Height="68"/>

                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>



                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">

                </StackPanel>



                <ContentControl x:Name="PagesContainer" 

                Grid.Row="1" 

                Margin="25"

                HorizontalContentAlignment="Stretch" 

                VerticalContentAlignment="Stretch"

                x:FieldModifier="public">



                    <Grid>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="Auto"/>

                            <RowDefinition Height="*"/>

                        </Grid.RowDefinitions>



                        <StackPanel Grid.Row="0" Margin="0,0,0,30">

                            <TextBlock Text="أهلاً بك دكتور محمد، طاب يومك! 👋" 

                       FontSize="28" FontWeight="Bold" Foreground="Black"/>

                            <TextBlock Text="إليك نظرة سريعة على نشاط العيادة اليوم." 

                       FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,0"/>

                        </StackPanel>



                        <UniformGrid Grid.Row="1" Columns="3" VerticalAlignment="Top">



                            <Border Margin="10" Background="White" CornerRadius="20" Padding="20">

                                <Border.Effect>

                                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.05"/>

                                </Border.Effect>

                                <StackPanel>

                                    <Border Width="45" Height="45" Background="#E3F2FD" CornerRadius="12" HorizontalAlignment="Right">

                                        <TextBlock Text="👥" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    </Border>

                                    <TextBlock Text="مرضى اليوم" FontSize="14" Foreground="#7F8C8D" Margin="0,15,0,5" HorizontalAlignment="Right"/>

                                    <TextBlock Text="24 مريض" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" Foreground="Black"/>

                                </StackPanel>

                            </Border>



                            <Border Margin="10" Background="White" CornerRadius="20" Padding="20">

                                <Border.Effect>

                                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.05"/>

                                </Border.Effect>

                                <StackPanel>

                                    <Border Width="45" Height="45" Background="#F1F8E9" CornerRadius="12" HorizontalAlignment="Right">

                                        <TextBlock Text="📅" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    </Border>

                                    <TextBlock Text="المواعيد القادمة" FontSize="14" Foreground="#7F8C8D" Margin="0,15,0,5" HorizontalAlignment="Right"/>

                                    <TextBlock Text="8 مواعيد" FontSize="24" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Right"/>

                                </StackPanel>

                            </Border>



                            <Border Margin="10" Background="White" CornerRadius="20" Padding="20">

                                <Border.Effect>

                                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.05"/>

                                </Border.Effect>

                                <StackPanel>

                                    <Border Width="45" Height="45" Background="#FFF3E0" CornerRadius="12" HorizontalAlignment="Right">

                                        <TextBlock Text="💰" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    </Border>

                                    <TextBlock Text="دخل اليوم" FontSize="14" Foreground="#7F8C8D" Margin="0,15,0,5" HorizontalAlignment="Right"/>

                                    <TextBlock Text="1,250 $" FontSize="24" FontWeight="Bold" Foreground="#27AE60" HorizontalAlignment="Right"/>

                                </StackPanel>

                            </Border>



                        </UniformGrid>



                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Opacity="0.1" IsHitTestVisible="False">

                            <TextBlock Text="🌙" FontSize="120" HorizontalAlignment="Center"/>

                            <TextBlock Text="Smart Clinic" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>

                        </StackPanel>



                    </Grid>

                </ContentControl>

            </Grid>

        </Grid>

    </Border>



</Window>