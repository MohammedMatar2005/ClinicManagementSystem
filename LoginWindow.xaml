<Window x:Class="ClinicManagementApplication.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClinicManagementApplication.ViewModels"
        Title="تسجيل الدخول" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" WindowStyle="None" 
        AllowsTransparency="True" Background="Transparent" FlowDirection="RightToLeft">

    <Window.DataContext>
        <vm:LoginViewModel />
    </Window.DataContext>

    <Border CornerRadius="30" Background="#1E293B" Margin="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.5" ShadowDepth="0" Color="#000"/>
        </Border.Effect>

        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="60,0,0,0">
                <TextBlock Text="مرحباً بك مجدداً 👋" FontSize="24" Foreground="#10B981" FontWeight="Light" Margin="0,0,0,10"/>
                <TextBlock Text="عيادة الشفاء الذكية" FontSize="42" FontWeight="ExtraBold" Foreground="White"/>
                <Rectangle Width="60" Height="5" Fill="#10B981" HorizontalAlignment="Right" Margin="0,15,0,30"/>

                <TextBlock Text="{Binding CurrentTime}" FontSize="56" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="{Binding CurrentDate}" FontSize="18" Foreground="#94A3B8" Margin="5,0,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="25">

                <Button Command="{Binding CloseCommand}" Content="✕" Width="35" Height="35" Cursor="Hand" Margin="0,0,10,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#334155"/>
                            <Setter Property="Foreground" Value="#EF4444"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="17.5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EF4444"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Command="{Binding MinimizeCommand}" Content="—" Width="35" Height="35" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#334155"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="17.5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#475569"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
            <Border Width="400" Height="550" Background="#F8FAFC" CornerRadius="30" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="500,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" Opacity="0.2" ShadowDepth="10"/>
                </Border.Effect>

                <StackPanel Margin="40">
                    <Border Width="80" Height="80" Background="#DCFCE7" CornerRadius="20" Margin="0,0,0,20">
                        <TextBlock Text="🏥" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="تسجيل الدخول" FontSize="28" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Center"/>
                    <TextBlock Text="الرجاء إدخال بيانات الاعتماد للوصول" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,8,0,40"/>

                    <TextBlock Text="اسم المستخدم" Foreground="#334155" FontWeight="Bold" FontSize="13" Margin="5,0,0,8"/>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="12" Height="55" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="👤" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#10B981" FontSize="18"/>
                            <TextBox x:Name="txtUser" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                     VerticalContentAlignment="Center" Padding="10,0" FontSize="16" Foreground="#1E293B"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="كلمة المرور" Foreground="#334155" FontWeight="Bold" FontSize="13" Margin="5,0,0,8"/>
                    <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="12" Height="55" Margin="0,0,0,35">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔒" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#10B981" FontSize="18"/>
                            <PasswordBox x:Name="txtPass" Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                         VerticalContentAlignment="Center" Padding="10,0" FontSize="16" Foreground="#1E293B"/>
                        </Grid>
                    </Border>

                    <Button Command="{Binding LoginCommand}" 
                            CommandParameter="{Binding ElementName=txtPass}"
                            Content="دخول النظام" Height="55" Background="#10B981" Foreground="White" FontSize="18" FontWeight="Bold" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#059669"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>