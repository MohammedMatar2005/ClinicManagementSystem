<UserControl x:Class="ClinicManagementApplication.Views.SupportUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900" FlowDirection="RightToLeft"
             xmlns:vm="clr-namespace:ClinicManagementApplication.ViewModels">
    <UserControl.DataContext>
        <vm:SupportViewModel/>
    </UserControl.DataContext>





<Grid Background="#F4F7FA">
        <Border Background="White" CornerRadius="25" Margin="40" VerticalAlignment="Center" HorizontalAlignment="Center" Width="550" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.1" Color="#1A2533"/>
            </Border.Effect>

            <StackPanel>
                <Border Width="110" Height="110" CornerRadius="55" HorizontalAlignment="Center" Margin="0,0,0,15" BorderBrush="#3498DB" BorderThickness="3">
                    <Border.Background>
                        <ImageBrush ImageSource="C:\Users\hp15-DW\Downloads\EditedPhoto.jfif" Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>

                <TextBlock Text="م. محمد مطر" FontSize="24" FontWeight="Bold" Foreground="#1A2533" HorizontalAlignment="Center"/>
                <TextBlock Text="Software Architect &amp; Backend Developer" Foreground="#3498DB" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,5,0,25"/>

                <Separator Background="#ECF0F1" Margin="20,0,20,20"/>

                <StackPanel Margin="15,0">

                    <DockPanel Margin="0,8">
                        <TextBlock Text="📞 الهاتف:" FontWeight="SemiBold" Foreground="#5D7A95" Width="120" VerticalAlignment="Center" FontSize="14"/>
                        <TextBox Text="00972599623752" Foreground="#2C3E50" FontWeight="Bold" FontSize="15" 
                                 IsReadOnly="True" BorderThickness="0" Background="Transparent" 
                                 VerticalAlignment="Center" Cursor="IBeam"/>
                    </DockPanel>

                    <DockPanel Margin="0,8">
                        <TextBlock Text="📧 البريد:" FontWeight="SemiBold" Foreground="#5D7A95" Width="120" VerticalAlignment="Center" FontSize="14"/>
                        <TextBox Text="matarmohammed567@gmail.com" Foreground="#2C3E50" FontWeight="Bold" FontSize="15" 
                                 IsReadOnly="True" BorderThickness="0" Background="Transparent" 
                                 VerticalAlignment="Center" Cursor="IBeam"/>
                    </DockPanel>

                    <DockPanel Margin="0,8">
                        <TextBlock Text="🔗 LinkedIn:" FontWeight="SemiBold" Foreground="#5D7A95" Width="120" VerticalAlignment="Center" FontSize="14"/>
                        <TextBox Text="linkedin.com/in/mohammed-matar-857962336" Foreground="#2C3E50" FontWeight="Bold" FontSize="14" 
                                 IsReadOnly="True" BorderThickness="0" Background="Transparent" 
                                 VerticalAlignment="Center" Cursor="IBeam" TextWrapping="Wrap"/>
                    </DockPanel>

                </StackPanel>

                <Border Background="#F0F9FF" CornerRadius="12" Padding="20" Margin="0,30,0,0" BorderBrush="#D6EAF8" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="ℹ️" Margin="0,0,10,0" VerticalAlignment="Top" FontSize="16"/>
                        <TextBlock Text="الدعم الفني متاح من السبت إلى الخميس&#x0a;من الساعة 9:00 صباحاً وحتى 5:00 مساءً" 
                                   Foreground="#34495E" FontSize="13" LineHeight="20" TextAlignment="Right"/>
                    </StackPanel>
                </Border>

                <UniformGrid Columns="2" Margin="0,25,0,0">
                    <Button x:Name="btnSendMessage" Content="إرسال رسالة" Height="45" Background="#1A2533" Foreground="White" FontWeight="Bold" Margin="5">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnWhatsApp" Content="واتساب" Height="45" Background="#27AE60" Foreground="White" FontWeight="Bold" Margin="5">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>