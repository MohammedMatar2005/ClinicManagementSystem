<UserControl x:Class="ClinicManagementApplication.Views.AppointmentsUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClinicManagementApplication.Views"
             xmlns:vm="clr-namespace:ClinicManagementApplication.ViewModels"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.DataContext>
        <vm:AppointmentsViewModel/>
    </UserControl.DataContext>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadDataCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Background="#F4F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Line -->
        <Border Grid.Row="0" Height="4" Background="#1A2533" CornerRadius="2" Margin="20,0">
            <Border.Effect>
                <DropShadowEffect Color="#1A2533" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
        </Border>

        <!-- Input Form Section -->
        <Border Grid.Row="1" Background="White" CornerRadius="15" Margin="20,10" Padding="25">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="حجز موعد طبي جديد" FontSize="20" FontWeight="Bold" Foreground="#1A2533" Margin="0,0,0,20"/>

                <!-- Row 1: Patient Search & Reason -->
                <UniformGrid Columns="2" Margin="0,5">
                    <StackPanel Margin="10,5">
                        <TextBlock Text="بحث عن مريض (بالاسم)" Foreground="#5D7A95" Margin="0,0,0,5"/>
                        <!-- جعل الـ ComboBox قابلاً للبحث بالاسم -->
                        <ComboBox x:Name="cbPatientName" 
                                  ItemsSource="{Binding Patients}" 
                                  SelectedItem="{Binding SelectedPatient}"
                                  DisplayMemberPath="FullName" 
                                  IsEditable="True" 
                                  IsTextSearchEnabled="True"
                                  StaysOpenOnEdit="True"
                                  Height="38" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="10,5">
                        <TextBlock Text="سبب الزيارة" Foreground="#5D7A95" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding ReasonForVisit, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="38" VerticalContentAlignment="Center" Padding="8"/>
                    </StackPanel>
                </UniformGrid>

                <!-- Row 2: Doctor, Date, Status -->
                <UniformGrid Columns="3" Margin="0,5">
                    <StackPanel Margin="10,5">
                        <TextBlock Text="الطبيب المختص" Foreground="#5D7A95" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding Doctors}" 
                                  SelectedItem="{Binding SelectedDoctor}"
                                  SelectedValue="{Binding SelectedDoctor.FullName}"
                                  DisplayMemberPath="FullName" 
                                  SelectedValuePath="DoctorId" 
                                  Height="38" VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Margin="10,5">
                        <TextBlock Text="تاريخ ووقت الموعد" Foreground="#5D7A95" Margin="0,0,0,5"/>
                        <!-- استخدام حقل واحد للتاريخ والوقت يسهل التعامل مع Database -->
                        <DatePicker SelectedDate="{Binding AppointmentDate}" Height="38"/>
                    </StackPanel>

                    <StackPanel Margin="10,5">
                        <TextBlock Text="حالة الموعد" Foreground="#5D7A95" Margin="0,0,0,5"/>
                        <ComboBox SelectedValue="{Binding StatusId}" 
                                  SelectedValuePath="Tag" 
                                  Height="38" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="مؤكد" Tag="1"/>
                            <ComboBoxItem Content="انتظار" Tag="2"/>
                            <ComboBoxItem Content="ملغي" Tag="3"/>
                        </ComboBox>
                    </StackPanel>
                </UniformGrid>

                <!-- Row 3: Notes -->
                <StackPanel Margin="10,5">
                    <TextBlock Text="ملاحظات إضافية" Foreground="#5D7A95" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Notes}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Padding="8"/>
                </StackPanel>

                <Button x:Name="btnSave" Command="{Binding SaveCommand}" Content="تأكيد وحفظ الموعد" 
                        Background="#2ECC71" Foreground="White" FontWeight="Bold" 
                        Height="45" Margin="10,15,10,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#27AE60"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Data Grid Section -->
        <Border Grid.Row="2" Background="White" CornerRadius="15" Margin="20,10,20,20" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel LastChildFill="False" Margin="10,0,10,15">
                    <TextBlock Text="جدول المواعيد المسجلة" FontSize="18" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <CheckBox IsChecked="{Binding IsActive}" Content="المواعيد النشطة فقط" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Command="{Binding RefreshCommand}" Content="🔄 تحديث" Background="Transparent" Foreground="#3498DB" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                    </StackPanel>
                </DockPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Appointments}" 
                          SelectedItem="{Binding SelectedAppointment}" 
                          AutoGenerateColumns="False" CanUserAddRows="False" 
                          GridLinesVisibility="None" Background="White" BorderThickness="0">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="المريض" Binding="{Binding PatientFullName}" Width="*"/>
                        <DataGridTextColumn Header="الطبيب" Binding="{Binding DoctorFullName}" Width="*"/>
                        <DataGridTextColumn Header="سبب الزيارة" Binding="{Binding ReasonForVisit}" Width="150"/>
                        <DataGridTextColumn Header="التاريخ والوقت" Binding="{Binding AppointmentDate, StringFormat=\{0:yyyy/MM/dd HH:mm\}}" Width="150"/>
                        <DataGridTextColumn Header="الحالة" Binding="{Binding StatusName}" Width="100"/>
                        <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive}" Width="60"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>