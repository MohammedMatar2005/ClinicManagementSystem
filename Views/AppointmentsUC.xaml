<UserControl x:Class="ClinicManagementApplication.Views.AppointmentsUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ClinicProject.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000">

    <UserControl.DataContext>
        <vm:AppointmentsViewModel/>
    </UserControl.DataContext>

    <Grid Background="#F4F7FA">
        <TabControl Background="Transparent" BorderThickness="0" Margin="10">
            <!-- الاستايل الخاص بالـ Tabs لجعلها تبدو عصرية -->
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="16"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="Margin" Value="0,0,5,0"/>
                </Style>
            </TabControl.Resources>

            <!-- التابة الأولى: إدارة المواعيد -->
            <TabItem Header="📅 حجز موعد" FlowDirection="RightToLeft">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Height="4" Background="#1A2533" CornerRadius="2" Margin="10,5"/>

                    <Border Grid.Row="1" Background="White" CornerRadius="15" Margin="10,20" Padding="25" VerticalAlignment="Top">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>

                        <StackPanel>
                            <TextBlock Text="بيانات الموعد الطبي" FontSize="22" FontWeight="Bold" Foreground="#1A2533" Margin="0,0,0,25"/>

                            <!-- Row 1: Patient & Reason -->
                            <UniformGrid Columns="2">
                                <StackPanel Margin="10">
                                    <TextBlock Text="المريض" Margin="0,0,0,8" Foreground="#5D7A95" FontWeight="Medium"/>
                                    <ComboBox ItemsSource="{Binding Patients}" 
                                              SelectedItem="{Binding SelectedPatient}"
                                              DisplayMemberPath="PatientFullName" 
                                              IsEditable="True" Height="40"/>
                                </StackPanel>
                                <StackPanel Margin="10">
                                    <TextBlock Text="سبب الزيارة" Margin="0,0,0,8" Foreground="#5D7A95" FontWeight="Medium"/>
                                    <TextBox Text="{Binding CurrentAppointment.ReasonForVisit, UpdateSourceTrigger=PropertyChanged}" Height="40"/>
                                </StackPanel>
                            </UniformGrid>

                            <!-- Row 2: Doctor, Date, Status -->
                            <UniformGrid Columns="3">
                                <StackPanel Margin="10">
                                    <TextBlock Text="الطبيب" Margin="0,0,0,8" Foreground="#5D7A95" FontWeight="Medium"/>
                                    <ComboBox ItemsSource="{Binding Doctors}" 
                                              SelectedItem="{Binding SelectedDoctor}" 
                                              DisplayMemberPath="DoctorFullName" Height="40"/>
                                </StackPanel>
                                <StackPanel Margin="10">
                                    <TextBlock Text="تاريخ الموعد" Margin="0,0,0,8" Foreground="#5D7A95" FontWeight="Medium"/>
                                    <DatePicker SelectedDate="{Binding CurrentAppointment.AppointmentDate}" Height="40"/>
                                </StackPanel>
                                <StackPanel Margin="10">
                                    <TextBlock Text="الحالة" Margin="0,0,0,8" Foreground="#5D7A95" FontWeight="Medium"/>
                                    <ComboBox SelectedValue="{Binding CurrentAppointment.StatusId, UpdateSourceTrigger=PropertyChanged}" 
          SelectedValuePath="Tag" 
          Height="40"
          FlowDirection="RightToLeft">

                                        <ComboBoxItem Content="انتظار">
                                            <ComboBoxItem.Tag>
                                                <sys:Int32>1</sys:Int32>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>

                                        <ComboBoxItem Content="مؤكد">
                                            <ComboBoxItem.Tag>
                                                <sys:Int32>2</sys:Int32>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>

                                        <ComboBoxItem Content="مكتمل">
                                            <ComboBoxItem.Tag>
                                                <sys:Int32>3</sys:Int32>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>

                                        <ComboBoxItem Content="ملغي">
                                            <ComboBoxItem.Tag>
                                                <sys:Int32>4</sys:Int32>
                                            </ComboBoxItem.Tag>
                                        </ComboBoxItem>

                                    </ComboBox>
                                </StackPanel>
                            </UniformGrid>

                            <!-- Notes Section -->
                            <StackPanel Margin="10">
                                <TextBlock Text="ملاحظات إضافية" Margin="0,0,0,8" Foreground="#5D7A95" FontWeight="Medium"/>
                                <TextBox Text="{Binding CurrentAppointment.Notes}" 
                                         Height="80" AcceptsReturn="True" TextWrapping="Wrap" Padding="5"/>
                            </StackPanel>

                            <!-- Control Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,30,10,0">
                                <Button Content="حذف الموعد" Command="{Binding DeleteCommand}" 
                                        Background="#E74C3C" Foreground="White" Width="120" Height="42" Margin="5"/>
                                <Button Content="جديد" Command="{Binding ClearCommand}" 
                                        Width="120" Height="42" Margin="5"/>
                                <Button Content="حفظ البيانات" Command="{Binding SaveCommand}" 
                                        Background="#2ECC71" Foreground="White" Width="120" Height="42" Margin="5"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <!-- التابة الثانية: سجل الفواتير -->
            <TabItem Header="💳 سجل المواعيد" FlowDirection="RightToLeft">
                <Border Background="White" CornerRadius="15" Margin="10" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="عرض المواعيد" FontSize="20" FontWeight="Bold" Foreground="#1A2533" Margin="0,0,0,20"/>

                        <!-- Filters for Invoices -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="بحث بإسم الطبيب:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtSearchValue" Width="150" Height="30" Margin="0,0,20,0"/>
                            <Button x:Name="btnSearch"  Content="🔍 بحث" Padding="15,0" Height="30" Background="#3498DB" Foreground="White" />
                            
                        </StackPanel>

                        <!-- Invoices Grid -->
                        <DataGrid Grid.Row="2" ItemsSource="{Binding Appointments}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ColumnWidth="*">
                            <DataGrid.Columns>
                                <!-- جعلنا الرقم ثابت العرض -->
                                <DataGridTextColumn Header="رقم الموعد" Binding="{Binding AppointmentId}" Width="Auto"/>

                                <!-- استخدمنا "*" هنا ليتمدد العمود ويملأ الفراغ -->
                                <DataGridTextColumn Header="المريض" Binding="{Binding PatientFullName}" Width="2*"/>

                                <DataGridTextColumn Header="الطبيب" Binding="{Binding DoctorFullName}" Width="2*"/>

                                <DataGridTextColumn Header="التاريخ" Binding="{Binding AppointmentDate, StringFormat={}{0:yyyy/MM/dd}}" Width="150"/>

                                <DataGridTextColumn Header="الحالة" Binding="{Binding StatusName}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding StatusColor}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>