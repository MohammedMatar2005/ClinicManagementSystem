<UserControl x:Class="ClinicManagementApplication.Views.PharmacyUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ClinicManagementApplication.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800" FlowDirection="RightToLeft">

    <UserControl.DataContext>
        <vm:PharmacyViewModel/>
    </UserControl.DataContext>

    <Grid Background="#F4F7FA">
        <Border Background="White" CornerRadius="20" Margin="50" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="600">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel HorizontalAlignment="Center" Margin="40">
                <TextBlock Text="🛠️" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="نظام إدارة الصيدلية" FontSize="24" FontWeight="Bold" Foreground="#1A2533" HorizontalAlignment="Center"/>

                <Separator Margin="0,15" Background="#EFF2F5" Width="200"/>

                <TextBlock Text="هذه الميزة تتطلب إعدادات متقدمة ونظاماً منفصلاً لإدارة المخزون والباركود." 
                           Foreground="#8FA3B8" FontSize="16" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10"/>

                <TextBlock Text="نحن نعمل حالياً على تطوير هذا القسم ليكون متكاملاً مع سجلات المرضى." 
                           Foreground="#3498DB" FontSize="14" FontWeight="SemiBold" TextAlignment="Center" Margin="0,5,0,20"/>

                <Button Content="العودة للرئيسية" 
                        Width="150" Height="45" 
                        Background="#1A2533" Foreground="White" 
                        FontWeight="Bold" Cursor="Hand"
                        Click="Button_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>