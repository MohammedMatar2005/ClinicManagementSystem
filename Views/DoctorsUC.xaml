<UserControl x:Class="ClinicManagementApplication.Views.DoctorsUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ClinicManagementApplication.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900" FlowDirection="RightToLeft">

    <UserControl.DataContext>
        <vm:DoctorsViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F7FAFC" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#3182CE" CornerRadius="8" Padding="15,10" Margin="0,0,0,15">
            <Grid>
                <TextBlock Text="{Binding RegistrationStepTitle}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBlock Foreground="#E2E8F0" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="المرحلة {0} من {1}">
                            <Binding Path="CurrentRegistrationStep" />
                            <Binding Path="TotalRegistrationSteps" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0" SelectedIndex="{Binding RegistrationStepIndex}" BorderThickness="0" Background="Transparent">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.Resources>

                    <TabItem>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <UniformGrid Columns="2" VerticalAlignment="Top">
                                <StackPanel Margin="10">
                                    <TextBlock Text="الاسم الأول" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedPerson.FirstName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="الاسم الثاني" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedPerson.SecondName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="الاسم الثالث" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedPerson.ThirdName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="العائلة / اللقب" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedPerson.LastName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="رقم الهوية" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedPerson.NationalNumber, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="رقم الجوال" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedPerson.Phone, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="الجنس" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox SelectedValue="{Binding SelectedPerson.Gender, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="ذكر" Tag="1"/>
                                        <ComboBoxItem Content="أنثى" Tag="0"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="العنوان" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedPerson.Address, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </UniformGrid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <StackPanel VerticalAlignment="Top">
                            <UniformGrid Columns="2">
                                <StackPanel Margin="10">
                                    <TextBlock Text="الطبيب المرتبط" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedPerson.FullName, Mode=OneWay}" IsReadOnly="True" Background="#EDF2F7" FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="اسم المستخدم" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedUser.Username, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="كلمة المرور" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding SelectedUser.PasswordHash, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="تأكيد كلمة المرور" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="الصلاحية" Style="{StaticResource FieldLabel}"/>
                                    <ComboBox SelectedValue="{Binding SelectedUser.RoleId, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag">
                                        <ComboBoxItem Content="طبيب" Tag="2"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Margin="10" VerticalAlignment="Center">
                                    <CheckBox Content="الحساب نشط وفوري الفعالية" IsChecked="{Binding SelectedUser.IsActive, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="Medium"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </TabItem>

                    <TabItem>
                        <StackPanel VerticalAlignment="Top">
                            <UniformGrid Columns="2">
                                <StackPanel Margin="10">
                                    <TextBlock Text="رقم الرخصة الطبية" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding CurrentDoctor.LicenseNumber, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="التخصص الطبي" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding CurrentDoctor.Specialization, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="موقع العيادة / المكتب" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding CurrentDoctor.OfficeLocation, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="الراتب الشهري" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding CurrentDoctor.Salary, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10">
                                    <TextBlock Text="سنوات الخبرة" Style="{StaticResource FieldLabel}"/>
                                    <TextBox Text="{Binding CurrentDoctor.ExperienceYears, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Margin="10" VerticalAlignment="Center">
                                    <CheckBox Content="طبيب نشط بالمنظومة" IsChecked="{Binding CurrentDoctor.IsActive, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="Medium"/>
                                </StackPanel>
                            </UniformGrid>

                            <Button Content="إتمام حفظ بيانات الطبيب بالكامل" Command="{Binding SaveDoctorCommand}" Background="#48BB78" Foreground="White" FontWeight="Bold" Height="42" Margin="10,20,10,10"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <Grid Grid.Row="1" Margin="0,15,0,0">
                    <Button Content="السابق" Command="{Binding BackCommand}" HorizontalAlignment="Right" Width="110" Height="38" Background="#A0AEC0" Foreground="White" FontWeight="Medium"/>
                    <Button Content="التالي" Command="{Binding NextCommand}" HorizontalAlignment="Left" Width="110" Height="38" Background="#3182CE" Foreground="White" FontWeight="Medium"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>